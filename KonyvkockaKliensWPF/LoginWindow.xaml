<Window x:Class="KonyvkockaKliensWPF.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:KonyvkockaKliensWPF"
        mc:Ignorable="d"
        Title="Bejelentkezés - KönyvKocka" 
        Height="300" Width="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" 
                   Text="Bejelentkezés" 
                   FontSize="24" 
                   FontWeight="Bold" 
                   HorizontalAlignment="Center" 
                   Margin="0,20,0,20"/>

        <StackPanel Grid.Row="1" Margin="20,0,20,10">
            <TextBlock Text="Email:" Margin="0,0,0,5"/>
            <TextBox x:Name="UsernameTextBox" 
                     Height="30" 
                     FontSize="14"
                     KeyDown="TextBox_KeyDown"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="20,0,20,10">
            <TextBlock Text="Jelszó:" Margin="0,0,0,5"/>
            <PasswordBox x:Name="PasswordBox" 
                         Height="30" 
                         FontSize="14"
                         KeyDown="PasswordBox_KeyDown"/>
        </StackPanel>

        <TextBlock x:Name="ErrorMessageTextBlock" 
                   Grid.Row="3" 
                   Foreground="Red" 
                   HorizontalAlignment="Center" 
                   Margin="20,5,20,10"
                   TextWrapping="Wrap"/>

        <Button Grid.Row="4" 
                Content="Bejelentkezés" 
                Width="150" 
                Height="35" 
                FontSize="14"
                Margin="0,0,0,20"
                Click="LoginButton_Click"/>

        <TextBlock Grid.Row="5" 
                   x:Name="AttemptsTextBlock"
                   Text="Hátralévő próbálkozások: 3"
                   HorizontalAlignment="Center" 
                   VerticalAlignment="Bottom"
                   Margin="0,0,0,10"
                   Foreground="Gray"/>
    </Grid>
</Window>
