<Window x:Class="KonyvkockaKliensWPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:KonyvkockaKliensWPF"
        mc:Ignorable="d"
        Title="KönyvKocka - KliensWPF" 
        Height="700" Width="1000"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- Tab header stílus -->
        <Style x:Key="ModernTabItem" TargetType="TabItem">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="20,12"/>
            <Setter Property="Margin" Value="0,0,5,0"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Border" 
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="0"
                                CornerRadius="8,8,0,0"
                                Margin="2,0">
                            <ContentPresenter x:Name="ContentSite"
                                            VerticalAlignment="Center"
                                            HorizontalAlignment="Center"
                                            ContentSource="Header"
                                            Margin="{TemplateBinding Padding}"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Border" Property="Margin" Value="2,0,2,-2"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Border" Property="Opacity" Value="0.85"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" 
                Background="#C29D59" 
                Padding="25">
            <TextBlock Text="KönyvKocka - Felhasználók Kezelése" 
                       FontSize="28" 
                       FontWeight="Bold" 
                       Foreground="White"
                       HorizontalAlignment="Center"/>
        </Border>

        <!-- Fül rendszer -->
        <TabControl Grid.Row="1" 
                    Margin="20"
                    BorderThickness="0">

            <!-- 1. Fül: Listázás -->
            <TabItem Style="{StaticResource ModernTabItem}"
                     Background="#4CAF50"
                     Foreground="White">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="📋" FontSize="20" Margin="0,0,8,0"/>
                        <TextBlock Text="Felhasználók listája" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                <Border Background="#E8F5E9" Padding="20">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="15"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Row="0" 
                                   Grid.ColumnSpan="3"
                                   Text="Összes felhasználó" 
                                   FontSize="22" 
                                   FontWeight="Bold" 
                                   Foreground="#2E7D32"
                                   Margin="0,0,0,8"/>

                        <TextBlock Grid.Row="1"
                                   Grid.ColumnSpan="3"
                                   Text="Jelölj ki egy felhasználót a táblázatban a részletes nézethez."
                                   Foreground="#4E6E53"
                                   Margin="0,0,0,12"/>

                        <DataGrid Grid.Row="1" 
                                  Grid.RowSpan="2"
                                  Grid.Column="0"
                                  x:Name="UsersDataGrid"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  AlternatingRowBackground="#F1F8E9"
                                  GridLinesVisibility="Horizontal"
                                  HeadersVisibility="Column"
                                  MinRowHeight="35"
                                  IsReadOnly="True"
                                  SelectionMode="Single"
                                  SelectionChanged="UsersDataGrid_SelectionChanged">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="60"/>
                                <DataGridTextColumn Header="Felhasználónév" Binding="{Binding Username}" Width="*"/>
                                <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="*"/>
                                <DataGridCheckBoxColumn Header="Előfizető" Binding="{Binding Premium}" Width="90"/>
                                <DataGridTextColumn Header="Szint" Binding="{Binding Level}" Width="60"/>
                                <DataGridTextColumn Header="Utolsó belépés" Binding="{Binding LastLoginDate}" Width="180"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <Border Grid.Row="2"
                                Grid.Column="2"
                                Background="#F9FFF7"
                                BorderBrush="#AED7AF"
                                BorderThickness="1"
                                CornerRadius="10"
                                Padding="14">
                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                          HorizontalScrollBarVisibility="Disabled">
                                <StackPanel TextElement.Foreground="#1F2933">
                                    <TextBlock Text="Kijelölt felhasználó" FontWeight="Bold" FontSize="18" Foreground="#2E7D32" Margin="0,0,0,10"/>

                                    <TextBlock x:Name="DetailsPlaceholderTextBlock"
                                               Text="Nincs kijelölt felhasználó."
                                               Foreground="#5D7C60"
                                               Margin="0,0,0,10"/>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                            <RowDefinition Height="Auto"/>
                                        </Grid.RowDefinitions>

                                        <TextBlock Text="ID:" FontWeight="SemiBold" Margin="0,0,8,6"/>
                                        <TextBlock Grid.Column="1" x:Name="DetailsIdTextBlock" Margin="0,0,0,6" TextWrapping="Wrap"/>

                                        <TextBlock Grid.Row="1" Text="Felhasználónév:" FontWeight="SemiBold" Margin="0,0,8,6"/>
                                        <TextBlock Grid.Row="1" Grid.Column="1" x:Name="DetailsUsernameTextBlock" Margin="0,0,0,6" TextWrapping="Wrap"/>

                                        <TextBlock Grid.Row="2" Text="Email:" FontWeight="SemiBold" Margin="0,0,8,6"/>
                                        <TextBlock Grid.Row="2" Grid.Column="1" x:Name="DetailsEmailTextBlock" Margin="0,0,0,6" TextWrapping="Wrap"/>

                                        <TextBlock Grid.Row="3" Text="Szerepkör:" FontWeight="SemiBold" Margin="0,0,8,6"/>
                                        <TextBlock Grid.Row="3" Grid.Column="1" x:Name="DetailsPermissionTextBlock" Margin="0,0,0,6" TextWrapping="Wrap"/>

                                        <TextBlock Grid.Row="4" Text="Előfizetés:" FontWeight="SemiBold" Margin="0,0,8,6"/>
                                        <TextBlock Grid.Row="4" Grid.Column="1" x:Name="DetailsSubscriptionTextBlock" Margin="0,0,0,6" TextWrapping="Wrap"/>

                                        <TextBlock Grid.Row="5" Text="Szint / XP:" FontWeight="SemiBold" Margin="0,0,8,6"/>
                                        <TextBlock Grid.Row="5" Grid.Column="1" x:Name="DetailsLevelXpTextBlock" Margin="0,0,0,6" TextWrapping="Wrap"/>

                                        <TextBlock Grid.Row="6" Text="Pontok:" FontWeight="SemiBold" Margin="0,0,8,6"/>
                                        <TextBlock Grid.Row="6" Grid.Column="1" x:Name="DetailsPointsTextBlock" Margin="0,0,0,6" TextWrapping="Wrap"/>

                                        <TextBlock Grid.Row="7" Text="Streak:" FontWeight="SemiBold" Margin="0,0,8,6"/>
                                        <TextBlock Grid.Row="7" Grid.Column="1" x:Name="DetailsStreakTextBlock" Margin="0,0,0,6" TextWrapping="Wrap"/>

                                        <TextBlock Grid.Row="8" Text="Aktivitás:" FontWeight="SemiBold" Margin="0,0,8,6"/>
                                        <TextBlock Grid.Row="8" Grid.Column="1" x:Name="DetailsActivityTextBlock" Margin="0,0,0,6" TextWrapping="Wrap"/>

                                        <TextBlock Grid.Row="9" Text="Utolsó belépés:" FontWeight="SemiBold" Margin="0,0,8,0"/>
                                        <TextBlock Grid.Row="9" Grid.Column="1" x:Name="DetailsLastLoginTextBlock" TextWrapping="Wrap"/>
                                    </Grid>
                                </StackPanel>
                            </ScrollViewer>
                        </Border>
                    </Grid>
                </Border>
            </TabItem>

            <!-- 2. Fül: Módosítás -->
            <TabItem Style="{StaticResource ModernTabItem}"
                     Background="#FF9800"
                     Foreground="White">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="✏️" FontSize="20" Margin="0,0,8,0"/>
                        <TextBlock Text="Felhasználó módosítása" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                <Border Background="#FFF3E0" Padding="20">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel MaxWidth="600" HorizontalAlignment="Center">
                            <TextBlock Text="Felhasználó adatainak módosítása" 
                                       FontSize="22" 
                                       FontWeight="Bold" 
                                       Foreground="#E65100"
                                       Margin="0,0,0,20"/>

                            <!-- Felhasználó kiválasztása -->
                            <TextBlock Text="Felhasználó kiválasztása:" Foreground="Black" Margin="0,0,0,5" FontWeight="SemiBold"/>
                            <ComboBox x:Name="EditUserComboBox" Height="35" FontSize="14" Margin="0,0,0,20"/>

                            <!-- Két oszlopos elrendezés -->
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="20"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                    <RowDefinition Height="Auto"/>
                                </Grid.RowDefinitions>

                                <!-- Bal oldal -->
                                <!-- Felhasználónév -->
                                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,0,10">
                                    <TextBlock Text="Felhasználónév:" Foreground="Black" Margin="0,0,0,5"/>
                                    <TextBox x:Name="EditUsernameTextBox" Height="35" FontSize="14"/>
                                </StackPanel>

                                <!-- Email -->
                                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,0,10">
                                    <TextBlock Text="Email:" Foreground="Black" Margin="0,0,0,5"/>
                                    <TextBox x:Name="EditEmailTextBox" Height="35" FontSize="14"/>
                                </StackPanel>

                                <!-- Ország -->
                                <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,0,10">
                                    <TextBlock Text="Ország kód:" Foreground="Black" Margin="0,0,0,5"/>
                                    <TextBox x:Name="EditCountryTextBox" Height="35" FontSize="14"/>
                                </StackPanel>

                                <!-- Jogosultság -->
                                <StackPanel Grid.Row="3" Grid.Column="0" Margin="0,0,0,10">
                                    <TextBlock Text="Jogosultság:" Foreground="Black" Margin="0,0,0,5"/>
                                    <ComboBox x:Name="EditPermissionComboBox" Height="35" FontSize="14"/>
                                </StackPanel>

                                <!-- Előfizetés típus -->
                                <StackPanel Grid.Row="4" Grid.Column="0" Margin="0,0,0,10">
                                    <TextBlock Text="Előfizetés csomag:" Foreground="Black" Margin="0,0,0,5"/>
                                    <ComboBox x:Name="EditSubscriptionTypeComboBox" Height="35" FontSize="14"/>
                                </StackPanel>

                                <!-- Szint -->
                                <StackPanel Grid.Row="5" Grid.Column="0" Margin="0,0,0,10">
                                    <TextBlock Text="Szint:" Foreground="Black" Margin="0,0,0,5"/>
                                    <TextBox x:Name="EditLevelTextBox" Height="35" FontSize="14"/>
                                </StackPanel>

                                <!-- Jobb oldal -->
                                <!-- Könyv Pontok -->
                                <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,0,10">
                                    <TextBlock Text="Könyv Pontok:" Foreground="Black" Margin="0,0,0,5"/>
                                    <TextBox x:Name="EditBookPointsTextBox" Height="35" FontSize="14"/>
                                </StackPanel>

                                <!-- Sorozat Pontok -->
                                <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,0,10">
                                    <TextBlock Text="Sorozat Pontok:" Foreground="Black" Margin="0,0,0,5"/>
                                    <TextBox x:Name="EditSeriesPointsTextBox" Height="35" FontSize="14"/>
                                </StackPanel>

                                <!-- Film Pontok -->
                                <StackPanel Grid.Row="2" Grid.Column="2" Margin="0,0,0,10">
                                    <TextBlock Text="Film Pontok:" Foreground="Black" Margin="0,0,0,5"/>
                                    <TextBox x:Name="EditFilmPointsTextBox" Height="35" FontSize="14"/>
                                </StackPanel>

                                <!-- Napi Sorozat -->
                                <StackPanel Grid.Row="3" Grid.Column="2" Margin="0,0,0,10">
                                    <TextBlock Text="Napi Sorozat (streak):" Foreground="Black" Margin="0,0,0,5"/>
                                    <TextBox x:Name="EditDayStreakTextBox" Height="35" FontSize="14"/>
                                </StackPanel>

                                <!-- Olvasási idő -->
                                <StackPanel Grid.Row="4" Grid.Column="2" Margin="0,0,0,10">
                                    <TextBlock Text="Olvasási idő (perc):" Foreground="Black" Margin="0,0,0,5"/>
                                    <TextBox x:Name="EditReadingTimeTextBox" Height="35" FontSize="14"/>
                                </StackPanel>

                                <!-- Nézési idő -->
                                <StackPanel Grid.Row="5" Grid.Column="2" Margin="0,0,0,10">
                                    <TextBlock Text="Nézési idő (perc):" Foreground="Black" Margin="0,0,0,5"/>
                                    <TextBox x:Name="EditWatchingTimeTextBox" Height="35" FontSize="14"/>
                                </StackPanel>
                            </Grid>

                            <StackPanel Margin="0,10,0,0">
                                <TextBlock Text="Előfizetés vége:" Foreground="Black" Margin="0,0,0,5"/>
                                <DatePicker x:Name="EditPremiumExpiresDatePicker" Height="35" FontSize="14" Margin="0,0,0,10"/>
                                <CheckBox x:Name="EditResetProfilePictureCheckBox"
                                          Content="Profilkép visszaállítása alapértelmezettre"
                                          FontSize="14"
                                          Height="30"/>

                                <Border Background="#FFF8F0" BorderBrush="#F4C48A" BorderThickness="1" CornerRadius="8" Padding="12" Margin="0,12,0,0">
                                    <StackPanel>
                                        <TextBlock Text="Jelszó módosítása (opcionális)" FontWeight="SemiBold" Foreground="#A24E00" Margin="0,0,0,8"/>
                                        <TextBlock Text="Új jelszó:" Foreground="Black" Margin="0,0,0,5"/>
                                        <PasswordBox x:Name="EditNewPasswordBox" Height="35" FontSize="14" Margin="0,0,0,10"/>
                                        <TextBlock Text="Új jelszó megerősítése:" Foreground="Black" Margin="0,0,0,5"/>
                                        <PasswordBox x:Name="EditConfirmNewPasswordBox" Height="35" FontSize="14"/>
                                    </StackPanel>
                                </Border>
                            </StackPanel>

                            <Button Content="💾 Módosítások mentése" 
                                    Background="#FF9800" 
                                    Foreground="White"
                                    FontSize="16"
                                    FontWeight="Bold"
                                    Height="45"
                                    Margin="0,20,0,0"
                                    BorderThickness="0"
                                    Cursor="Hand" Click="UpdateUserButton_Click"/>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </TabItem>

            <!-- 3. Fül: Törlés -->
            <TabItem Style="{StaticResource ModernTabItem}"
                     Background="#F44336"
                     Foreground="White">
                <TabItem.Header>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="🗑️" FontSize="20" Margin="0,0,8,0"/>
                        <TextBlock Text="Felhasználó törlése" VerticalAlignment="Center"/>
                    </StackPanel>
                </TabItem.Header>
                <Border Background="#FFEBEE" Padding="20">
                    <StackPanel MaxWidth="560" VerticalAlignment="Center">
                        <TextBlock Text="Felhasználó törlése" 
                                   FontSize="22" 
                                   FontWeight="Bold" 
                                   Foreground="#C62828"
                                   Margin="0,0,0,14"/>

                        <TextBlock Text="A törlés előtt ellenőrizd a kiválasztott felhasználót, majd gépeld be pontosan a felhasználónevét megerősítésként."
                                   Foreground="#7E2A2A"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,14"/>

                        <Border Background="#FFCDD2" 
                                BorderBrush="#F44336" 
                                BorderThickness="2" 
                                CornerRadius="5"
                                Padding="15"
                                Margin="0,0,0,30">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="⚠️" FontSize="24" Margin="0,0,10,0"/>
                                <TextBlock Text="Figyelem! A törlés végleges és visszafordíthatatlan!" 
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="#C62828"
                                           TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="Felhasználó kiválasztása:" Foreground="Black" Margin="0,0,0,5"/>
                        <ComboBox x:Name="DeleteUserComboBox"
                                  Height="35"
                                  FontSize="14"
                                  Margin="0,0,0,16"
                                  SelectionChanged="DeleteUserComboBox_SelectionChanged"/>

                        <Border Background="#FFEEF0"
                                BorderBrush="#F44336"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="12"
                                Margin="0,0,0,16">
                            <StackPanel>
                                <TextBlock Text="Törlésre kijelölt felhasználó" FontWeight="Bold" Foreground="#B71C1C" Margin="0,0,0,8"/>
                                <TextBlock x:Name="DeletePreviewTextBlock" Text="Nincs kijelölt felhasználó." TextWrapping="Wrap"/>
                            </StackPanel>
                        </Border>

                        <TextBlock Text="Megerősítés: írd be a felhasználónevet" Foreground="Black" Margin="0,0,0,5" FontWeight="SemiBold"/>
                        <TextBox x:Name="DeleteConfirmTextBox"
                                 Height="35"
                                 FontSize="14"
                                 Margin="0,0,0,6"
                                 TextChanged="DeleteConfirmTextBox_TextChanged"/>
                        <TextBlock x:Name="DeleteValidationTextBlock"
                                   Foreground="#C62828"
                                   Margin="0,0,0,18"/>

                        <Button Content="⚠️ Felhasználó törlése" 
                                x:Name="DeleteUserButton"
                                Background="#F44336" 
                                Foreground="White"
                                FontSize="16"
                                FontWeight="Bold"
                                Height="45"
                                BorderThickness="0"
                                Cursor="Hand"
                                IsEnabled="False"
                                Click="DeleteUserButton_Click"/>
                    </StackPanel>
                </Border>
            </TabItem>

        </TabControl>
    </Grid>
</Window>
